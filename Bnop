-- ЛОГИКА
-- ============================================
local bhopEnabled = false
local speedPerSec = 0.15
local currentMultiplier = 1.0
local activeTime = 0
local lastJumpTime = 0
local jumpCooldown = 0.05
local lastPosition = nil
local currentSpeed = 0
local isMoving = false
local stopTimer = 0
local stopThreshold = 0.5 -- секунд без движения для сброса

-- Проверка земли
local function checkGround()
    local char = player.Character
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    
    local ray = Ray.new(root.Position, Vector3.new(0, -3.5, 0))
    local hit = workspace:FindPartOnRay(ray, char)
    return hit ~= nil
end

-- Проверка движения
local function isPlayerMoving()
    local char = player.Character
    if not char then return false end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    
    if lastPosition then
        local distance = (root.Position - lastPosition).Magnitude
        return distance > 0.5
    end
    return false
end

-- Расчёт скорости
local function updateSpeed()
    local char = player.Character
    if not char then 
        currentSpeed = 0
        return 
    end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then 
        currentSpeed = 0
        return 
    end
    
    local currentPos = root.Position
    
    if lastPosition then
        local distance = (currentPos - lastPosition).Magnitude
        local deltaTime = 1/60
        if deltaTime > 0 then
            currentSpeed = distance / deltaTime
        end
    end
    
    lastPosition = currentPos
end

-- Основной цикл
runService.RenderStepped:Connect(function(dt)
    updateSpeed()
    
    -- Обновление спидометра
    speedoText.Text = string.format("%.1f", currentSpeed)
    speedInfoText.Text = "SPEED: " .. string.format("%.1f", currentSpeed) .. " u/s"
    
    -- Цвет спидометра
    if currentSpeed >= 200 then
        speedoText.TextColor3 = Color3.fromRGB(255, 50, 50)
        speedInfoText.TextColor3 = Color3.fromRGB(255, 50, 50)
    elseif currentSpeed >= 100 then
        speedoText.TextColor3 = Color3.fromRGB(255, 180, 50)
        speedInfoText.TextColor3 = Color3.fromRGB(255, 180, 50)
    elseif currentSpeed >= 50 then
        speedoText.TextColor3 = Color3.fromRGB(255, 255, 100)
        speedInfoText.TextColor3 = Color3.fromRGB(255, 255, 100)
    else
        speedoText.TextColor3 = Color3.fromRGB(255, 255, 255)
        speedInfoText.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
    
    -- Принудительное первое лицо
    if fppEnabled and player.Character then
        player.CameraMode = Enum.CameraMode.LockFirstPerson
        player.CameraMinZoomDistance = 0
        player.CameraMaxZoomDistance = 0
    end
    
    if not bhopEnabled then 
        lastPosition = nil
        currentMultiplier = 1.0
        activeTime = 0
        return 
    end
    
    -- Проверка движения для таймера сброса
    if isPlayerMoving() then
        isMoving = true
        stopTimer = 0
    else
        if isMoving then
            stopTimer = stopTimer + dt
            if stopTimer >= stopThreshold then
                -- Полная остановка - сброс скорости
                isMoving = false
                currentMultiplier = 1.0
                activeTime = 0
                multiplierInfoText.Text = "x1.00 | Time: 0s"
                multiplierInfoText.TextColor3 = Color3.fromRGB(150, 150, 170)
            end
        end
    end
    
    -- Накапливание скорости каждую секунду при движении и прыжках
    if isMoving then
        activeTime = activeTime + dt
        
        -- Увеличиваем множитель каждую секунду
        if activeTime >= 1.0 then
            currentMultiplier = currentMultiplier + speedPerSec
            activeTime = activeTime - 1.0
            
            multiplierInfoText.Text = string.format("x%.2f | Time: %ds", currentMultiplier, math.floor(activeTime * 10) / 10)
            if currentMultiplier >= 10 then
                multiplierInfoText.TextColor3 = Color3.fromRGB(255, 50, 50)
            elseif currentMultiplier >= 5 then
                multiplierInfoText.TextColor3 = Color3.fromRGB(255, 180, 50)
            else
                multiplierInfoText.TextColor3 = Color3.fromRGB(130, 255, 130)
            end
        end
    end
    
    -- BHop прыжки при зажатом пробеле
    if uis:IsKeyDown(Enum.KeyCode.Space) then
        local char = player.Character
        if not char then return end
        
        local humanoid = char:FindFirstChild("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        
        if humanoid and root and checkGround() then
            local currentTime = tick()
            if currentTime - lastJumpTime > jumpCooldown then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                lastJumpTime = currentTime
                
                -- Применяем ускорение
                local humanoidMoveDir = humanoid.MoveDirection
                if humanoidMoveDir.Magnitude > 0 then
                    local velocity = root.Velocity
                    local boost = humanoidMoveDir.Unit * (currentMultiplier * 12)
                    root.Velocity = Vector3.new(
                        velocity.X + boost.X,
                        velocity.Y,
                        velocity.Z + boost.Z
                    )
                end
            end
        end
    end
end)

-- Установка скорости ходьбы
runService.Heartbeat:Connect(function()
    if bhopEnabled and player.Character then
        local humanoid = player.Character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid.WalkSpeed = 16 * currentMultiplier
        end
    end
end)

